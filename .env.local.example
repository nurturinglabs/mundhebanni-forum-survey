NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# /admin dashboard password (server-side only — never prefixed with NEXT_PUBLIC_)
DASHBOARD_PASSWORD=pick-a-strong-password

# Supabase service-role key (server-side only — bypasses RLS for admin reads)
# Supabase → Settings → API → service_role secret. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
